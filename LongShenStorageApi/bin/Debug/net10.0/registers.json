{
  "deviceName": "汇川Easy522 堆垛机",
  "protocol": "Modbus TCP D区寄存器",
  "description": "上位机通过Modbus TCP读写D区寄存器与堆垛机PLC通信。可在此文件中增删改寄存器定义，重启API后生效。",

  "readRegisters": [
    { "address": 4008, "name": "设备序号", "description": "堆垛机设备编号", "unit": "" },
    { "address": 4009, "name": "立库状态", "description": "1:空闲中 2:运行中 3:故障中 4:暂停中", "unit": "" },
    { "address": 4010, "name": "故障异常代码", "description": "0:正常", "unit": "" },
    { "address": 4011, "name": "运行模式", "description": "1:手动 2:自动", "unit": "" },
    { "address": 4012, "name": "动作步骤", "description": "当前执行到的步骤编号", "unit": "" },
    { "address": 4013, "name": "A->B任务完成", "description": "1:完成 2:执行中", "unit": "" },
    { "address": 4014, "name": "托盘转移状态", "description": "1:尚未取到托盘 2:已转移到堆垛车 3:已转移到目标位置", "unit": "" },
    { "address": 4015, "name": "备用", "description": "", "unit": "" },
    { "address": 4016, "name": "X轴实时位置", "description": "X轴(列方向)当前位置", "unit": "mm" },
    { "address": 4017, "name": "Y轴实时位置", "description": "Y轴(层方向)当前位置", "unit": "mm" },
    { "address": 4018, "name": "Z轴深库位置", "description": "Z轴深库伸叉位置", "unit": "mm" },
    { "address": 4019, "name": "Z轴浅库位置", "description": "Z轴浅库伸叉位置", "unit": "mm" },
    { "address": 4020, "name": "是否可以移库", "description": "1:可以 2:不可以", "unit": "" },
    { "address": 4021, "name": "左侧入库口可入库", "description": "1:可以 2:不可以", "unit": "" },
    { "address": 4022, "name": "左侧出库口可出库", "description": "1:可以 2:不可以", "unit": "" },
    { "address": 4023, "name": "右侧入库口可入库", "description": "1:可以 2:不可以", "unit": "" },
    { "address": 4024, "name": "右侧出库口可出库", "description": "1:可以 2:不可以", "unit": "" },
    { "address": 4025, "name": "A->B动作是否已完成", "description": "0:未完成 1:已完成", "unit": "" },
    { "address": 4026, "name": "堆垛车当前位置", "description": "101+ 车位号", "unit": "" },
    { "address": 4027, "name": "预留1", "description": "", "unit": "" },
    { "address": 4028, "name": "预留2", "description": "", "unit": "" },
    { "address": 4029, "name": "预留3", "description": "", "unit": "" },
    { "address": 4030, "name": "预留4", "description": "", "unit": "" },
    { "address": 4031, "name": "预留5", "description": "", "unit": "" }
  ],

  "writeRegisters": [
    { "address": 2022, "name": "设备序号", "description": "堆垛机设备编号(1~N)", "unit": "" },
    { "address": 2023, "name": "动作序列/标志位", "description": "动作序列号每次递增；写入此位触发执行(1:有动作)", "unit": "" },
    { "address": 2024, "name": "排", "description": "货位排号", "unit": "" },
    { "address": 2025, "name": "列", "description": "货位列号(1-4)", "unit": "" },
    { "address": 2026, "name": "层", "description": "货位层号(1-8)", "unit": "" },
    { "address": 2027, "name": "预留1", "description": "", "unit": "" },
    { "address": 2028, "name": "预留2", "description": "", "unit": "" },
    { "address": 2029, "name": "预留3", "description": "", "unit": "" }
  ]
}
