{
  "deviceName": "汇川Easy522 堆垛机",
  "protocol": "Modbus TCP D区寄存器",
  "description": "上位机通过Modbus TCP读写D区寄存器与堆垛机PLC通信。可在此文件中增删改寄存器定义，重启API后生效。",

  "readRegisters": [
    { "address": 100, "name": "立库状态", "description": "1:空闲中 2:运行中 3:故障中 4:暂停中", "unit": "" },
    { "address": 101, "name": "故障异常代码", "description": "0:正常", "unit": "" },
    { "address": 102, "name": "运行模式", "description": "1:手动 2:自动", "unit": "" },
    { "address": 103, "name": "动作步骤", "description": "当前执行到的步骤编号", "unit": "" },
    { "address": 104, "name": "A->B任务完成", "description": "1:完成 2:执行中", "unit": "" },
    { "address": 105, "name": "托盘转移状态", "description": "1:尚未取到托盘 2:已转移到堆垛车 3:已转移到目标位置", "unit": "" },
    { "address": 106, "name": "备用", "description": "", "unit": "" },
    { "address": 107, "name": "X轴实时位置", "description": "X轴(列方向)当前位置", "unit": "mm" },
    { "address": 108, "name": "Y轴实时位置", "description": "Y轴(层方向)当前位置", "unit": "mm" },
    { "address": 109, "name": "Z轴深库位置", "description": "Z轴深库伸叉位置", "unit": "mm" },
    { "address": 110, "name": "Z轴浅库位置", "description": "Z轴浅库伸叉位置", "unit": "mm" },
    { "address": 111, "name": "是否可以移库", "description": "1:可以 2:不可以", "unit": "" },
    { "address": 112, "name": "左侧入库口可入库", "description": "1:可以 2:不可以", "unit": "" },
    { "address": 113, "name": "左侧出库口可出库", "description": "1:可以 2:不可以", "unit": "" },
    { "address": 114, "name": "右侧入库口可入库", "description": "1:可以 2:不可以", "unit": "" },
    { "address": 115, "name": "右侧出库口可出库", "description": "1:可以 2:不可以", "unit": "" },
    { "address": 116, "name": "A->B动作是否已完成", "description": "0:未完成 1:已完成", "unit": "" },
    { "address": 117, "name": "堆垛车当前位置", "description": "101+ 车位号", "unit": "" }
  ],

  "writeRegisters": [
    { "address": 101, "name": "设备序号", "description": "堆垛机设备编号(1~N)", "unit": "" },
    { "address": 102, "name": "序列1", "description": "动作序列号，每次递增", "unit": "" },
    { "address": 103, "name": "动作标志位", "description": "1:有动作(写入此位触发执行)", "unit": "" },
    { "address": 104, "name": "A:排", "description": "11:入库位置 12:出库位置", "unit": "" },
    { "address": 105, "name": "A:列", "description": "取货位列号(1-4)", "unit": "" },
    { "address": 106, "name": "A:层", "description": "取货位层号(1-8)", "unit": "" },
    { "address": 107, "name": "B:排", "description": "放货位排号", "unit": "" },
    { "address": 108, "name": "B:列", "description": "放货位列号(1-4)", "unit": "" },
    { "address": 109, "name": "B:层", "description": "放货位层号(1-8)", "unit": "" },
    { "address": 110, "name": "附加参数1", "description": "扩展参数", "unit": "" },
    { "address": 111, "name": "附加参数2", "description": "扩展参数", "unit": "" },
    { "address": 112, "name": "动作类型", "description": "1:默认无动作 2:出库 3:入库 4:移库 5:直接出", "unit": "" },
    { "address": 113, "name": "出库后续动作", "description": "1:默认无动作 11:线体1号位 12:线体2号位", "unit": "" },
    { "address": 114, "name": "起始地址", "description": "", "unit": "" },
    { "address": 115, "name": "目标地址", "description": "", "unit": "" },
    { "address": 116, "name": "其他参数", "description": "", "unit": "" }
  ]
}
